{
  "__inputs": [
    {
      "name": "DS_INFLUXDB",
      "label": "InfluxDB",
      "description": "piccolo-perf InfluxDB v2 datasource",
      "type": "datasource",
      "pluginId": "influxdb"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "influxdb", "name": "InfluxDB", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "bargauge", "name": "Bar gauge", "version": "" },
    { "type": "panel", "id": "table", "name": "Table", "version": "" }
  ],
  "title": "piccolo-perf — Bandwidth",
  "uid": "piccolo-bandwidth",
  "description": "TCP throughput measurements — native and iperf3",
  "tags": ["piccolo-perf", "bandwidth", "throughput"],
  "schemaVersion": 38,
  "version": 1,
  "refresh": "5m",
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {},
  "templating": {
    "list": [
      {
        "name": "bucket",
        "label": "Bucket",
        "type": "constant",
        "current": { "value": "piccolo" },
        "hide": 0
      },
      {
        "name": "source",
        "label": "Source",
        "type": "query",
        "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
        "query": "import \"influxdata/influxdb/schema\"\nschema.tagValues(bucket: \"${bucket}\", tag: \"source\", predicate: (r) => r._measurement == \"piccolo_bw\")",
        "multi": true,
        "includeAll": true,
        "current": { "text": "All", "value": "$__all" }
      },
      {
        "name": "method",
        "label": "Method",
        "type": "query",
        "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
        "query": "import \"influxdata/influxdb/schema\"\nschema.tagValues(bucket: \"${bucket}\", tag: \"method\", predicate: (r) => r._measurement == \"piccolo_bw\")",
        "multi": true,
        "includeAll": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "TX Throughput over time (Mbps)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 8 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "targets": [
        {
          "query": "from(bucket: \"${bucket}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"piccolo_bw\" and r._field == \"bw_tx_mbps\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\n  |> map(fn: (r) => ({ r with _field: r.source + \" → \" + r.target + \" (\" + r[\"method\"] + \")\" }))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Mbps",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "min", "max"] }
      }
    },
    {
      "id": 2,
      "title": "RX Throughput over time — iperf3 only (Mbps)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 24, "h": 7 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "targets": [
        {
          "query": "from(bucket: \"${bucket}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"piccolo_bw\" and r._field == \"bw_rx_mbps\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\n  |> map(fn: (r) => ({ r with _field: r.source + \" → \" + r.target }))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "Mbps", "custom": { "lineWidth": 1, "lineStyle": { "dash": [4, 4] } } }
      }
    },
    {
      "id": 3,
      "title": "Current TX throughput per link",
      "type": "bargauge",
      "gridPos": { "x": 0, "y": 15, "w": 16, "h": 7 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "targets": [
        {
          "query": "from(bucket: \"${bucket}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"piccolo_bw\" and r._field == \"bw_tx_mbps\")\n  |> last()\n  |> map(fn: (r) => ({ r with _field: r.source + \" → \" + r.target + \" (\" + r[\"method\"] + \")\" }))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "Mbps", "min": 0 }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "displayMode": "gradient"
      }
    },
    {
      "id": 4,
      "title": "Measurement method breakdown",
      "type": "stat",
      "gridPos": { "x": 16, "y": 15, "w": 8, "h": 7 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "targets": [
        {
          "query": "from(bucket: \"${bucket}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"piccolo_bw\" and r._field == \"bw_tx_mbps\")\n  |> group(columns: [\"method\"])\n  |> count()\n  |> map(fn: (r) => ({ r with _field: r[\"method\"] }))",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none"
      }
    },
    {
      "id": 5,
      "title": "Throughput summary table",
      "type": "table",
      "gridPos": { "x": 0, "y": 22, "w": 24, "h": 7 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "targets": [
        {
          "query": "from(bucket: \"${bucket}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"piccolo_bw\" and r._field == \"bw_tx_mbps\")\n  |> group(columns: [\"source\", \"target\", \"site\", \"method\"])\n  |> reduce(fn: (r, accumulator) => ({ count: accumulator.count + 1, sum: accumulator.sum + r._value, min: if r._value < accumulator.min then r._value else accumulator.min, max: if r._value > accumulator.max then r._value else accumulator.max }), identity: { count: 0, sum: 0.0, min: 99999.0, max: 0.0 })\n  |> map(fn: (r) => ({ r with mean: r.sum / float(v: r.count) }))\n  |> keep(columns: [\"source\", \"target\", \"site\", \"method\", \"mean\", \"min\", \"max\", \"count\"])\n  |> rename(columns: { mean: \"Avg (Mbps)\", min: \"Min (Mbps)\", max: \"Max (Mbps)\", count: \"Samples\" })",
          "refId": "A"
        }
      ],
      "options": { "sortBy": [{ "displayName": "Avg (Mbps)", "desc": true }] },
      "fieldConfig": {
        "overrides": [
          { "matcher": { "id": "byName", "options": "Avg (Mbps)" }, "properties": [{ "id": "unit", "value": "Mbps" }, { "id": "decimals", "value": 1 }] },
          { "matcher": { "id": "byName", "options": "Min (Mbps)" }, "properties": [{ "id": "unit", "value": "Mbps" }, { "id": "decimals", "value": 1 }] },
          { "matcher": { "id": "byName", "options": "Max (Mbps)" }, "properties": [{ "id": "unit", "value": "Mbps" }, { "id": "decimals", "value": 1 }] }
        ]
      }
    }
  ]
}
