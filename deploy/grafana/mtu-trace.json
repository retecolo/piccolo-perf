{
  "__inputs": [
    {
      "name": "DS_INFLUXDB",
      "label": "InfluxDB",
      "description": "piccolo-perf InfluxDB v2 datasource",
      "type": "datasource",
      "pluginId": "influxdb"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "influxdb", "name": "InfluxDB", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "table", "name": "Table", "version": "" },
    { "type": "panel", "id": "stateTimeline", "name": "State timeline", "version": "" }
  ],
  "title": "piccolo-perf — MTU & Traceroute",
  "uid": "piccolo-mtu-trace",
  "description": "Path MTU discovery and per-hop traceroute latency",
  "tags": ["piccolo-perf", "mtu", "traceroute", "path"],
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10m",
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {},
  "templating": {
    "list": [
      {
        "name": "bucket",
        "label": "Bucket",
        "type": "constant",
        "current": { "value": "piccolo" },
        "hide": 0
      },
      {
        "name": "source",
        "label": "Source",
        "type": "query",
        "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
        "query": "import \"influxdata/influxdb/schema\"\nschema.tagValues(bucket: \"${bucket}\", tag: \"source\", predicate: (r) => r._measurement == \"piccolo_mtu\")",
        "multi": true,
        "includeAll": true,
        "current": { "text": "All", "value": "$__all" }
      },
      {
        "name": "target",
        "label": "Target",
        "type": "query",
        "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
        "query": "import \"influxdata/influxdb/schema\"\nschema.tagValues(bucket: \"${bucket}\", tag: \"target\", predicate: (r) => r._measurement == \"piccolo_mtu\")",
        "multi": true,
        "includeAll": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 100,
      "title": "PATH MTU",
      "type": "row",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 1,
      "title": "Effective Path MTU over time (bytes)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 1, "w": 24, "h": 8 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "targets": [
        {
          "query": "from(bucket: \"${bucket}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"piccolo_mtu\" and r._field == \"mtu_effective_bytes\" and r[\"skipped\"] == \"false\")\n  |> aggregateWindow(every: v.windowPeriod, fn: min, createEmpty: false)\n  |> map(fn: (r) => ({ r with _field: r.source + \" → \" + r.target }))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "min": 576,
          "custom": { "lineWidth": 2, "fillOpacity": 5, "spanNulls": true },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": 576 },
              { "color": "yellow", "value": 1280 },
              { "color": "green", "value": 1500 }
            ]
          }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "min", "max"] }
      }
    },
    {
      "id": 2,
      "title": "Current MTU per link",
      "type": "table",
      "gridPos": { "x": 0, "y": 9, "w": 12, "h": 6 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "targets": [
        {
          "query": "from(bucket: \"${bucket}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"piccolo_mtu\" and r._field == \"mtu_effective_bytes\" and r[\"skipped\"] == \"false\")\n  |> last()\n  |> keep(columns: [\"source\", \"target\", \"site\", \"_value\", \"_time\"])\n  |> rename(columns: { _value: \"MTU (bytes)\", _time: \"Last seen\" })",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "MTU (bytes)" },
            "properties": [
              { "id": "unit", "value": "bytes" },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "red", "value": 576 }, { "color": "yellow", "value": 1280 }, { "color": "green", "value": 1500 }] } },
              { "id": "custom.displayMode", "value": "color-background" }
            ]
          }
        ]
      }
    },
    {
      "id": 3,
      "title": "MTU change detection (state timeline)",
      "type": "stateTimeline",
      "gridPos": { "x": 12, "y": 9, "w": 12, "h": 6 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "targets": [
        {
          "query": "from(bucket: \"${bucket}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"piccolo_mtu\" and r._field == \"mtu_effective_bytes\" and r[\"skipped\"] == \"false\")\n  |> map(fn: (r) => ({ r with _field: r.source + \" → \" + r.target }))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": 576 },
              { "color": "yellow", "value": 1280 },
              { "color": "green", "value": 1500 }
            ]
          }
        }
      },
      "options": { "mergeValues": true }
    },
    {
      "id": 200,
      "title": "TRACEROUTE",
      "type": "row",
      "gridPos": { "x": 0, "y": 15, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 4,
      "title": "Hop count over time",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 7 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "targets": [
        {
          "query": "from(bucket: \"${bucket}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"piccolo_trace\" and r._field == \"trace_hops\" and r[\"skipped\"] == \"false\")\n  |> aggregateWindow(every: v.windowPeriod, fn: max, createEmpty: false)\n  |> map(fn: (r) => ({ r with _field: r.source + \" → \" + r.target }))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "custom": { "lineWidth": 1, "drawStyle": "points", "pointSize": 4 }
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "min", "max"] } }
    },
    {
      "id": 5,
      "title": "Trace complete rate over time",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 7 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "targets": [
        {
          "query": "from(bucket: \"${bucket}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"piccolo_trace\" and r._field == \"trace_complete\" and r[\"skipped\"] == \"false\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\n  |> map(fn: (r) => ({ r with _value: r._value * 100.0, _field: r.source + \" → \" + r.target }))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "yellow", "value": 80 },
              { "color": "green", "value": 100 }
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "title": "Per-hop RTT over time — hop 1",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 23, "w": 12, "h": 7 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "targets": [
        {
          "query": "from(bucket: \"${bucket}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"piccolo_trace\" and r._field == \"hop_1_rtt_ms\" and r[\"skipped\"] == \"false\" and r._value >= 0.0)\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\n  |> map(fn: (r) => ({ r with _field: r.source + \" → \" + r.target + \" hop 1\" }))",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" } }
    },
    {
      "id": 7,
      "title": "Current traceroute summary",
      "type": "table",
      "gridPos": { "x": 12, "y": 23, "w": 12, "h": 7 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "targets": [
        {
          "query": "from(bucket: \"${bucket}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"piccolo_trace\" and r._field == \"trace_hops\" and r[\"skipped\"] == \"false\")\n  |> last()\n  |> keep(columns: [\"source\", \"target\", \"site\", \"_value\", \"_time\"])\n  |> rename(columns: { _value: \"Hops\", _time: \"Last seen\" })",
          "refId": "A"
        }
      ]
    }
  ]
}
