{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "piccolo-perf Prometheus datasource",
      "type": "datasource",
      "pluginId": "prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "bargauge", "name": "Bar gauge", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" }
  ],
  "title": "piccolo-perf — Bandwidth (Prometheus)",
  "uid": "piccolo-prom-bandwidth",
  "description": "TCP throughput measurements via Prometheus",
  "tags": ["piccolo-perf", "prometheus", "bandwidth", "throughput"],
  "schemaVersion": 38,
  "version": 1,
  "refresh": "5m",
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {},
  "templating": {
    "list": [
      {
        "name": "source",
        "label": "Source",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "query": "label_values(piccolo_bw_bw_tx_mbps, source)",
        "multi": true,
        "includeAll": true,
        "current": { "text": "All", "value": "$__all" }
      },
      {
        "name": "method",
        "label": "Method",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "query": "label_values(piccolo_bw_bw_tx_mbps, method)",
        "multi": true,
        "includeAll": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "TX Throughput over time (Mbps)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "piccolo_bw_bw_tx_mbps{source=~\"$source\", method=~\"$method\"}",
          "legendFormat": "{{source}} → {{target}} ({{method}})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "Mbps", "custom": { "lineWidth": 2, "fillOpacity": 10 } }
      },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "min", "max", "last"] } }
    },
    {
      "id": 2,
      "title": "RX Throughput — iperf3 only (Mbps)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 24, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "piccolo_bw_bw_rx_mbps",
          "legendFormat": "{{source}} → {{target}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "Mbps", "custom": { "lineWidth": 1, "lineStyle": { "dash": [4, 4] } } } }
    },
    {
      "id": 3,
      "title": "Current TX throughput per link",
      "type": "bargauge",
      "gridPos": { "x": 0, "y": 15, "w": 16, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "piccolo_bw_bw_tx_mbps{source=~\"$source\", method=~\"$method\"}",
          "legendFormat": "{{source}} → {{target}} ({{method}})",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": { "defaults": { "unit": "Mbps", "min": 0 } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "horizontal", "displayMode": "gradient" }
    },
    {
      "id": 4,
      "title": "Method breakdown",
      "type": "stat",
      "gridPos": { "x": 16, "y": 15, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "count by (method) (piccolo_bw_bw_tx_mbps)",
          "legendFormat": "{{method}}",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none" }
    }
  ]
}
