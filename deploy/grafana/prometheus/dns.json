{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "piccolo-perf Prometheus datasource",
      "type": "datasource",
      "pluginId": "prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "table", "name": "Table", "version": "" }
  ],
  "title": "piccolo-perf — DNS (Prometheus)",
  "uid": "piccolo-prom-dns",
  "description": "DNS resolver latency and success rate via Prometheus",
  "tags": ["piccolo-perf", "prometheus", "dns", "resolver"],
  "schemaVersion": 38,
  "version": 1,
  "refresh": "2m",
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "templating": {
    "list": [
      {
        "name": "source",
        "label": "Source",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "query": "label_values(piccolo_dns_dns_rtt_ms, source)",
        "multi": true,
        "includeAll": true,
        "current": { "text": "All", "value": "$__all" }
      },
      {
        "name": "resolver",
        "label": "Resolver",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "query": "label_values(piccolo_dns_dns_rtt_ms, resolver)",
        "multi": true,
        "includeAll": true,
        "current": { "text": "All", "value": "$__all" }
      },
      {
        "name": "name",
        "label": "Name",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "query": "label_values(piccolo_dns_dns_rtt_ms, name)",
        "multi": true,
        "includeAll": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Resolver RTT over time",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "piccolo_dns_dns_rtt_ms{source=~\"$source\", resolver=~\"$resolver\", name=~\"$name\"}",
          "legendFormat": "{{source}} → {{resolver}} ({{name}})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ms", "custom": { "lineWidth": 1, "fillOpacity": 5 } }
      },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "min", "max", "p95"] } }
    },
    {
      "id": 2,
      "title": "Success rate over time",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 16, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "piccolo_dns_dns_success{source=~\"$source\", resolver=~\"$resolver\", name=~\"$name\"} * 100",
          "legendFormat": "{{source}} → {{resolver}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": 0 },
            { "color": "yellow", "value": 90 },
            { "color": "green", "value": 99 }
          ]},
          "custom": { "lineWidth": 1, "fillOpacity": 10 }
        }
      }
    },
    {
      "id": 3,
      "title": "Current success rate",
      "type": "stat",
      "gridPos": { "x": 16, "y": 8, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "piccolo_dns_dns_success{source=~\"$source\", resolver=~\"$resolver\", name=~\"$name\"} * 100",
          "legendFormat": "{{source}} → {{resolver}}",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": 0 },
            { "color": "yellow", "value": 90 },
            { "color": "green", "value": 99 }
          ]}
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },
    {
      "id": 4,
      "title": "RTT p50 / p95 / p99 over time",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 15, "w": 24, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "quantile(0.50, piccolo_dns_dns_rtt_ms{source=~\"$source\", resolver=~\"$resolver\"})",
          "legendFormat": "p50",
          "refId": "p50"
        },
        {
          "expr": "quantile(0.95, piccolo_dns_dns_rtt_ms{source=~\"$source\", resolver=~\"$resolver\"})",
          "legendFormat": "p95",
          "refId": "p95"
        },
        {
          "expr": "quantile(0.99, piccolo_dns_dns_rtt_ms{source=~\"$source\", resolver=~\"$resolver\"})",
          "legendFormat": "p99",
          "refId": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ms" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "p99" }, "properties": [{ "id": "custom.lineStyle", "value": { "dash": [6, 3] } }] }
        ]
      }
    },
    {
      "id": 5,
      "title": "Resolver summary — current values",
      "type": "table",
      "gridPos": { "x": 0, "y": 22, "w": 24, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "piccolo_dns_dns_rtt_ms{source=~\"$source\", resolver=~\"$resolver\", name=~\"$name\"}",
          "legendFormat": "{{source}} / {{resolver}} / {{name}}",
          "refId": "A",
          "instant": true
        },
        {
          "expr": "piccolo_dns_dns_success{source=~\"$source\", resolver=~\"$resolver\", name=~\"$name\"} * 100",
          "legendFormat": "{{source}} / {{resolver}} / {{name}}",
          "refId": "B",
          "instant": true
        }
      ],
      "fieldConfig": {
        "overrides": [
          { "matcher": { "id": "byName", "options": "Value #A" }, "properties": [{ "id": "displayName", "value": "RTT (ms)" }, { "id": "unit", "value": "ms" }, { "id": "decimals", "value": 2 }] },
          { "matcher": { "id": "byName", "options": "Value #B" }, "properties": [{ "id": "displayName", "value": "Success %" }, { "id": "unit", "value": "percent" }, { "id": "custom.displayMode", "value": "color-background" }, { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "red", "value": 0 }, { "color": "yellow", "value": 90 }, { "color": "green", "value": 99 }] } }] }
        ]
      },
      "options": { "sortBy": [{ "displayName": "RTT (ms)" }] }
    }
  ]
}
