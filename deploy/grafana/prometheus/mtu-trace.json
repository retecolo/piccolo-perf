{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "piccolo-perf Prometheus datasource",
      "type": "datasource",
      "pluginId": "prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "table", "name": "Table", "version": "" },
    { "type": "panel", "id": "stateTimeline", "name": "State timeline", "version": "" }
  ],
  "title": "piccolo-perf — MTU & Traceroute (Prometheus)",
  "uid": "piccolo-prom-mtu-trace",
  "description": "Path MTU discovery and traceroute hop latency via Prometheus",
  "tags": ["piccolo-perf", "prometheus", "mtu", "traceroute", "path"],
  "schemaVersion": 38,
  "version": 2,
  "refresh": "10m",
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {},
  "templating": {
    "list": [
      {
        "name": "source",
        "label": "Source",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "query": "label_values(piccolo_mtu_mtu_effective_bytes{job=\"piccolo_perf\"}, source)",
        "multi": true,
        "includeAll": true,
        "current": { "text": "All", "value": "$__all" }
      },
      {
        "name": "target",
        "label": "Target",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "query": "label_values(piccolo_mtu_mtu_effective_bytes{job=\"piccolo_perf\"}, target)",
        "multi": true,
        "includeAll": true,
        "current": { "text": "All", "value": "$__all" }
      },
      {
        "name": "site",
        "label": "Site",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "query": "label_values(piccolo_mtu_mtu_effective_bytes{job=\"piccolo_perf\"}, site)",
        "multi": true,
        "includeAll": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 100,
      "title": "PATH MTU",
      "type": "row",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 1,
      "title": "Effective Path MTU over time",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 1, "w": 24, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "piccolo_mtu_mtu_effective_bytes{job=\"piccolo_perf\", skipped=\"false\", source=~\"$source\", target=~\"$target\", site=~\"$site\"}",
          "legendFormat": "{{source}} → {{target}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "min": 576,
          "custom": { "lineWidth": 2, "fillOpacity": 5, "spanNulls": true },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": 576 },
            { "color": "yellow", "value": 1280 },
            { "color": "green", "value": 1500 }
          ]}
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "min", "max"] } }
    },
    {
      "id": 2,
      "title": "Current MTU per link",
      "type": "table",
      "gridPos": { "x": 0, "y": 9, "w": 12, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "piccolo_mtu_mtu_effective_bytes{job=\"piccolo_perf\", skipped=\"false\", source=~\"$source\", target=~\"$target\", site=~\"$site\"}",
          "legendFormat": "{{source}} → {{target}}",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "overrides": [
          { "matcher": { "id": "byName", "options": "Value" }, "properties": [
            { "id": "displayName", "value": "MTU (bytes)" },
            { "id": "unit", "value": "bytes" },
            { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "red", "value": 576 }, { "color": "yellow", "value": 1280 }, { "color": "green", "value": 1500 }] } },
            { "id": "custom.displayMode", "value": "color-background" }
          ]}
        ]
      }
    },
    {
      "id": 3,
      "title": "MTU state timeline",
      "type": "stateTimeline",
      "gridPos": { "x": 12, "y": 9, "w": 12, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "piccolo_mtu_mtu_effective_bytes{job=\"piccolo_perf\", skipped=\"false\", source=~\"$source\", target=~\"$target\", site=~\"$site\"}",
          "legendFormat": "{{source}} → {{target}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": 576 },
            { "color": "yellow", "value": 1280 },
            { "color": "green", "value": 1500 }
          ]}
        }
      },
      "options": { "mergeValues": true }
    },
    {
      "id": 200,
      "title": "TRACEROUTE",
      "type": "row",
      "gridPos": { "x": 0, "y": 15, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 4,
      "title": "Hop count over time",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "piccolo_trace_trace_hops{job=\"piccolo_perf\", skipped=\"false\", source=~\"$source\", target=~\"$target\", site=~\"$site\"}",
          "legendFormat": "{{source}} → {{target}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "decimals": 0, "custom": { "lineWidth": 1, "drawStyle": "points", "pointSize": 4 } }
      },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "min", "max"] } }
    },
    {
      "id": 5,
      "title": "Trace complete rate",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "piccolo_trace_trace_complete{job=\"piccolo_perf\", skipped=\"false\", source=~\"$source\", target=~\"$target\", site=~\"$site\"} * 100",
          "legendFormat": "{{source}} → {{target}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": 0 },
            { "color": "yellow", "value": 80 },
            { "color": "green", "value": 100 }
          ]}
        }
      }
    },
    {
      "id": 6,
      "title": "Hop 1 RTT over time",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 23, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "piccolo_trace_hop_1_rtt_ms{job=\"piccolo_perf\", skipped=\"false\", source=~\"$source\", target=~\"$target\", site=~\"$site\"} >= 0",
          "legendFormat": "{{source}} → {{target}} hop 1",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" } }
    },
    {
      "id": 7,
      "title": "Traceroute summary — current",
      "type": "table",
      "gridPos": { "x": 12, "y": 23, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "piccolo_trace_trace_hops{job=\"piccolo_perf\", skipped=\"false\", source=~\"$source\", target=~\"$target\", site=~\"$site\"}",
          "legendFormat": "{{source}} → {{target}}",
          "refId": "A",
          "instant": true
        },
        {
          "expr": "piccolo_trace_trace_complete{job=\"piccolo_perf\", skipped=\"false\", source=~\"$source\", target=~\"$target\", site=~\"$site\"}",
          "legendFormat": "{{source}} → {{target}}",
          "refId": "B",
          "instant": true
        }
      ],
      "fieldConfig": {
        "overrides": [
          { "matcher": { "id": "byName", "options": "Value #A" }, "properties": [{ "id": "displayName", "value": "Hops" }] },
          { "matcher": { "id": "byName", "options": "Value #B" }, "properties": [
            { "id": "displayName", "value": "Complete" },
            { "id": "custom.displayMode", "value": "color-background" },
            { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "red", "value": 0 }, { "color": "green", "value": 1 }] } }
          ]}
        ]
      }
    }
  ]
}
