{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "piccolo-perf Prometheus datasource",
      "type": "datasource",
      "pluginId": "prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "table", "name": "Table", "version": "" }
  ],
  "title": "piccolo-perf — Overview (Prometheus)",
  "uid": "piccolo-prom-overview",
  "description": "Fleet-wide summary of all piccolo-perf measurement types via Prometheus",
  "tags": ["piccolo-perf", "prometheus", "network", "performance"],
  "schemaVersion": 38,
  "version": 1,
  "refresh": "1m",
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "templating": {
    "list": [
      {
        "name": "source",
        "label": "Source",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "query": "label_values(piccolo_twamp_rtt_avg_ms, source)",
        "multi": true,
        "includeAll": true,
        "current": { "text": "All", "value": "$__all" }
      },
      {
        "name": "target",
        "label": "Target",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "query": "label_values(piccolo_twamp_rtt_avg_ms, target)",
        "multi": true,
        "includeAll": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "TWAMP RTT avg — all links",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "piccolo_twamp_rtt_avg_ms{source=~\"$source\", target=~\"$target\"}",
          "legendFormat": "{{source}} → {{target}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "lineWidth": 1, "fillOpacity": 5 }
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "min", "max"] } }
    },
    {
      "id": 2,
      "title": "Packet Loss %",
      "type": "stat",
      "gridPos": { "x": 0, "y": 8, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "piccolo_twamp_loss_pct{source=~\"$source\", target=~\"$target\"}",
          "legendFormat": "{{source}} → {{target}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": 0 },
            { "color": "yellow", "value": 1 },
            { "color": "red", "value": 5 }
          ]}
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },
    {
      "id": 3,
      "title": "Jitter",
      "type": "stat",
      "gridPos": { "x": 6, "y": 8, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "piccolo_twamp_jitter_ms{source=~\"$source\", target=~\"$target\"}",
          "legendFormat": "{{source}} → {{target}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": 0 },
            { "color": "yellow", "value": 5 },
            { "color": "red", "value": 20 }
          ]}
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },
    {
      "id": 4,
      "title": "Bandwidth TX (Mbps)",
      "type": "stat",
      "gridPos": { "x": 12, "y": 8, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "piccolo_bw_bw_tx_mbps{source=~\"$source\", target=~\"$target\"}",
          "legendFormat": "{{source}} → {{target}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "Mbps" } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" }
    },
    {
      "id": 5,
      "title": "DNS Success Rate",
      "type": "stat",
      "gridPos": { "x": 18, "y": 8, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "piccolo_dns_dns_success * 100",
          "legendFormat": "{{source}} → {{resolver}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": 0 },
            { "color": "yellow", "value": 90 },
            { "color": "green", "value": 99 }
          ]}
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },
    {
      "id": 6,
      "title": "Bandwidth over time",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "piccolo_bw_bw_tx_mbps{source=~\"$source\", target=~\"$target\"}",
          "legendFormat": "{{source}} → {{target}} ({{method}})",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "Mbps", "custom": { "lineWidth": 1 } } }
    },
    {
      "id": 7,
      "title": "DNS Resolver RTT over time",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "piccolo_dns_dns_rtt_ms",
          "legendFormat": "{{source}} → {{resolver}} ({{name}})",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ms", "custom": { "lineWidth": 1 } } }
    },
    {
      "id": 8,
      "title": "Path MTU — current",
      "type": "table",
      "gridPos": { "x": 0, "y": 19, "w": 12, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "piccolo_mtu_mtu_effective_bytes{skipped=\"false\"}",
          "legendFormat": "{{source}} → {{target}}",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "options": { "sortBy": [{ "displayName": "source" }] }
    },
    {
      "id": 9,
      "title": "Traceroute Hops — current",
      "type": "table",
      "gridPos": { "x": 12, "y": 19, "w": 12, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "piccolo_trace_trace_hops{skipped=\"false\"}",
          "legendFormat": "{{source}} → {{target}}",
          "refId": "A",
          "instant": true
        }
      ],
      "options": { "sortBy": [{ "displayName": "source" }] }
    }
  ]
}
