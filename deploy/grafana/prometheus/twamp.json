{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "piccolo-perf Prometheus datasource",
      "type": "datasource",
      "pluginId": "prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "bargauge", "name": "Bar gauge", "version": "" },
    { "type": "panel", "id": "heatmap", "name": "Heatmap", "version": "" }
  ],
  "title": "piccolo-perf — TWAMP-Light (Prometheus)",
  "uid": "piccolo-prom-twamp",
  "description": "RFC 5357 TWAMP-Light RTT, jitter, and packet loss via Prometheus",
  "tags": ["piccolo-perf", "prometheus", "twamp", "rtt", "latency"],
  "schemaVersion": 38,
  "version": 1,
  "refresh": "1m",
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "templating": {
    "list": [
      {
        "name": "source",
        "label": "Source",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "query": "label_values(piccolo_twamp_rtt_avg_ms, source)",
        "multi": true,
        "includeAll": true,
        "current": { "text": "All", "value": "$__all" }
      },
      {
        "name": "target",
        "label": "Target",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "query": "label_values(piccolo_twamp_rtt_avg_ms, target)",
        "multi": true,
        "includeAll": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "RTT avg over time",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "piccolo_twamp_rtt_avg_ms{source=~\"$source\", target=~\"$target\"}",
          "legendFormat": "{{source}} → {{target}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ms", "custom": { "lineWidth": 1, "fillOpacity": 5 } }
      },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "min", "max", "last"] } }
    },
    {
      "id": 2,
      "title": "RTT min / avg / max",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 16, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "piccolo_twamp_rtt_min_ms{source=~\"$source\", target=~\"$target\"}",
          "legendFormat": "min {{source}} → {{target}}",
          "refId": "A"
        },
        {
          "expr": "piccolo_twamp_rtt_avg_ms{source=~\"$source\", target=~\"$target\"}",
          "legendFormat": "avg {{source}} → {{target}}",
          "refId": "B"
        },
        {
          "expr": "piccolo_twamp_rtt_max_ms{source=~\"$source\", target=~\"$target\"}",
          "legendFormat": "max {{source}} → {{target}}",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ms", "custom": { "lineWidth": 1 } },
        "overrides": [
          { "matcher": { "id": "byRegexp", "options": "^min.*" }, "properties": [{ "id": "custom.lineStyle", "value": { "dash": [4, 4] } }] },
          { "matcher": { "id": "byRegexp", "options": "^max.*" }, "properties": [{ "id": "custom.lineStyle", "value": { "dash": [4, 4] } }] }
        ]
      }
    },
    {
      "id": 3,
      "title": "Std deviation",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 8, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "piccolo_twamp_rtt_stddev_ms{source=~\"$source\", target=~\"$target\"}",
          "legendFormat": "{{source}} → {{target}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" } }
    },
    {
      "id": 4,
      "title": "Jitter (mean absolute IPDV)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 15, "w": 16, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "piccolo_twamp_jitter_ms{source=~\"$source\", target=~\"$target\"}",
          "legendFormat": "{{source}} → {{target}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": 0 },
            { "color": "yellow", "value": 5 },
            { "color": "red", "value": 20 }
          ]}
        }
      }
    },
    {
      "id": 5,
      "title": "Packet loss %",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 15, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "piccolo_twamp_loss_pct{source=~\"$source\", target=~\"$target\"}",
          "legendFormat": "{{source}} → {{target}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": 0 },
            { "color": "yellow", "value": 1 },
            { "color": "red", "value": 5 }
          ]},
          "custom": { "fillOpacity": 20 }
        }
      }
    },
    {
      "id": 6,
      "title": "Packet loss per link — bar gauge",
      "type": "bargauge",
      "gridPos": { "x": 0, "y": 22, "w": 24, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "piccolo_twamp_loss_pct{source=~\"$source\", target=~\"$target\"}",
          "legendFormat": "{{source}} → {{target}}",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": 0 },
            { "color": "yellow", "value": 1 },
            { "color": "red", "value": 5 }
          ]}
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "horizontal", "displayMode": "gradient" }
    },
    {
      "id": 7,
      "title": "Packets sent vs received",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 28, "w": 12, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "piccolo_twamp_packets_sent{source=~\"$source\", target=~\"$target\"}",
          "legendFormat": "sent {{source}} → {{target}}",
          "refId": "A"
        },
        {
          "expr": "piccolo_twamp_packets_recv{source=~\"$source\", target=~\"$target\"}",
          "legendFormat": "recv {{source}} → {{target}}",
          "refId": "B"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 8,
      "title": "Reflected packets total",
      "type": "stat",
      "gridPos": { "x": 12, "y": 28, "w": 12, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "twamp_reflected_packets_total",
          "legendFormat": "{{source}}",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" }
    }
  ]
}
