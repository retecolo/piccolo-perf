{
  "__inputs": [
    {
      "name": "DS_INFLUXDB",
      "label": "InfluxDB",
      "description": "piccolo-perf InfluxDB v2 datasource",
      "type": "datasource",
      "pluginId": "influxdb"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "influxdb", "name": "InfluxDB", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "heatmap", "name": "Heatmap", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "bargauge", "name": "Bar gauge", "version": "" }
  ],
  "title": "piccolo-perf — TWAMP-Light",
  "uid": "piccolo-twamp",
  "description": "RFC 5357 TWAMP-Light RTT, jitter, and packet loss over time",
  "tags": ["piccolo-perf", "twamp", "rtt", "latency"],
  "schemaVersion": 38,
  "version": 1,
  "refresh": "1m",
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "templating": {
    "list": [
      {
        "name": "bucket",
        "label": "Bucket",
        "type": "constant",
        "current": { "value": "piccolo" },
        "hide": 0
      },
      {
        "name": "source",
        "label": "Source",
        "type": "query",
        "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
        "query": "import \"influxdata/influxdb/schema\"\nschema.tagValues(bucket: \"${bucket}\", tag: \"source\", predicate: (r) => r._measurement == \"piccolo_twamp\")",
        "multi": true,
        "includeAll": true,
        "current": { "text": "All", "value": "$__all" }
      },
      {
        "name": "target",
        "label": "Target",
        "type": "query",
        "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
        "query": "import \"influxdata/influxdb/schema\"\nschema.tagValues(bucket: \"${bucket}\", tag: \"target\", predicate: (r) => r._measurement == \"piccolo_twamp\")",
        "multi": true,
        "includeAll": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "RTT avg over time (ms)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 8 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "targets": [
        {
          "query": "from(bucket: \"${bucket}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"piccolo_twamp\" and r._field == \"rtt_avg_ms\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\n  |> map(fn: (r) => ({ r with _field: r.source + \" → \" + r.target }))",
          "refId": "A",
          "hide": false
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "lineWidth": 1, "fillOpacity": 5, "spanNulls": true }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "min", "max"] }
      }
    },
    {
      "id": 2,
      "title": "RTT min / avg / max",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 16, "h": 7 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "targets": [
        {
          "query": "from(bucket: \"${bucket}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"piccolo_twamp\" and (r._field == \"rtt_min_ms\" or r._field == \"rtt_avg_ms\" or r._field == \"rtt_max_ms\"))\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\n  |> map(fn: (r) => ({ r with _field: r.source + \" → \" + r.target + \" \" + r._field }))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "lineWidth": 1, "fillOpacity": 3 }
        },
        "overrides": [
          { "matcher": { "id": "byRegexp", "options": ".*rtt_min.*" }, "properties": [{ "id": "custom.lineStyle", "value": { "dash": [4, 4] } }] },
          { "matcher": { "id": "byRegexp", "options": ".*rtt_max.*" }, "properties": [{ "id": "custom.lineStyle", "value": { "dash": [4, 4] } }] }
        ]
      }
    },
    {
      "id": 3,
      "title": "RTT std deviation over time",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 8, "w": 8, "h": 7 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "targets": [
        {
          "query": "from(bucket: \"${bucket}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"piccolo_twamp\" and r._field == \"rtt_stddev_ms\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\n  |> map(fn: (r) => ({ r with _field: r.source + \" → \" + r.target }))",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" } }
    },
    {
      "id": 4,
      "title": "Jitter (mean absolute IPDV) over time",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 15, "w": 16, "h": 7 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "targets": [
        {
          "query": "from(bucket: \"${bucket}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"piccolo_twamp\" and r._field == \"jitter_ms\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\n  |> map(fn: (r) => ({ r with _field: r.source + \" → \" + r.target }))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "title": "Packet loss % over time",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 15, "w": 8, "h": 7 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "targets": [
        {
          "query": "from(bucket: \"${bucket}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"piccolo_twamp\" and r._field == \"loss_pct\")\n  |> aggregateWindow(every: v.windowPeriod, fn: max, createEmpty: false)\n  |> map(fn: (r) => ({ r with _field: r.source + \" → \" + r.target }))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          },
          "custom": { "fillOpacity": 20 }
        }
      }
    },
    {
      "id": 6,
      "title": "RTT avg heatmap (source × target)",
      "type": "heatmap",
      "gridPos": { "x": 0, "y": 22, "w": 24, "h": 8 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "targets": [
        {
          "query": "from(bucket: \"${bucket}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"piccolo_twamp\" and r._field == \"rtt_avg_ms\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" } },
      "options": {
        "calculate": false,
        "color": {
          "mode": "scheme",
          "scheme": "Spectral",
          "steps": 128
        },
        "yAxis": { "unit": "ms" }
      }
    },
    {
      "id": 7,
      "title": "Packet loss — bar gauge per link",
      "type": "bargauge",
      "gridPos": { "x": 0, "y": 30, "w": 24, "h": 6 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "targets": [
        {
          "query": "from(bucket: \"${bucket}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"piccolo_twamp\" and r._field == \"loss_pct\")\n  |> mean()\n  |> map(fn: (r) => ({ r with _field: r.source + \" → \" + r.target }))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["mean"] },
        "orientation": "horizontal",
        "displayMode": "gradient"
      }
    }
  ]
}
